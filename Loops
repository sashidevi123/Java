import java.util.Scanner;
public class Main{
public static void main(String[] args){
Scanner sc=new Scanner(System.in);
int T=sc.nextInt();
while(T>0){
int L=sc.nextInt();
int R=sc.nextInt();
int M=sc.nextInt();
int pages=M/L;
if(M%L != 0){
pages=pages+1;
}
int lines=M/R;
int s=pages+lines;
System.out.println(s);
T--;
}
sc.close();
}
}


