import java.util.Scanner;
public class Main {
public static void main(String[] args) {
Scanner sc = new Scanner(System.in);
int T = sc.nextInt();
while (T-- > 0) {
 int correctYes = 0;
int heroYes = 0;
for (int i = 0; i < 3; i++) {
 correctYes += sc.nextInt();
 }
for (int i = 0; i < 3; i++) {
heroYes += sc.nextInt();
}
if (correctYes == heroYes) {
System.out.println("Pass");
} else {
System.out.println("Fail");
}
}
sc.close();
 }
}
